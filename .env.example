# =============================================
# 카카오 API 설정
# =============================================
# 카카오 디벨로퍼스(https://developers.kakao.com)에서 발급
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_REDIRECT_URI=https://example.com/oauth

# 카카오 토큰 (token_manager.py 실행 후 자동 저장됨)
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=

# =============================================
# 네이버 오픈 API 설정
# =============================================
# 네이버 개발자 센터(https://developers.naver.com)에서 발급
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# =============================================
# 알림 설정
# =============================================
# 뉴스 수집 개수 (종목별)
NEWS_COUNT=5
# 리포트 수집 개수
REPORT_COUNT=3
